flags:
  rewrite: false

cert:
  issuer: letsencrypt-prod--argo-cd
  secretName: letsencrypt-prod-cert-secret-argo-cd

service:
  name: argo-cd-argocd-server
  port:
    number: 80

annotations:
  hajimari.io/enable: "true"
  hajimari.io/appName: "argocd"

ingress:
  name: argo-cd
  enableLocalDomain: "true"
  routePath: /
  subdomain: argo

hosts:
  - name: "mrsauravsahu.in"

