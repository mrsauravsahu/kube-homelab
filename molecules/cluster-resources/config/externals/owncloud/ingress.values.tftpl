flags:
  rewrite: false

cert:
  issuer: letsencrypt-prod-homelab
  secretName: letsencrypt-prod-cert-secret-owncloud

service:
  name: owncloud
  port:
    number: 80

annotations:
  hajimari.io/enable: "true"
  hajimari.io/appName: "owncloud"

ingress:
  name: owncloud
  enableLocalDomains: "false"
  subdomain: owncloud
  routePath: /

hosts:
#%{ for host in hosts ~}
#- name: ${host}
#%{ endfor ~}
  - name: "mrsauravsahu.in"
  - name: "192.168.200.200.nip.io"
