flags:
  rewrite: false

cert:
  issuer: letsencrypt-prod--homelab-keycloak
  secretName: le-issuer-account-key--homelab-keycloak--keycloak

service:
  name: keycloak
  port:
    number: 80

annotations:
  hajimari.io/enable: "true"
  hajimari.io/appName: "idp"

ingress:
  enableLocalDomains: "true"
  name: keycloak
  subdomain: idp
  routePath: /

hosts:
  - name: mrsauravsahu.in
  - name: 192.168.200.200.nip.io

